PORT=5000
MONGODB_URI=mongodb_connection_string_here
JWT_SECRET=your_super_secret_jwt_key_here
OTP_SECRET=your_separate_otp_hmac_secret_here
SAFETYNET_ENCRYPTION_KEY=64_character_hex_string_here
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=Manas <no-reply@example.com>
CLIENT_URL=https://your-frontend.example.com
CORS_ORIGIN=https://your-frontend.example.com
API_PUBLIC_URL=https://dose-backend-ezck.onrender.com
# Use TEST_EMAIL_REDIRECT in dev to catch all outgoing emails to one address
TEST_EMAIL_REDIRECT=pskedhar@gmail.com
SMS_PROVIDER=mock
# Set SMS_PROVIDER=twilio and configure the following for real SMS delivery:
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
# If Twilio fails (trial limits, India DLT, region blocks), fall back to mock so OTP is still usable:
SMS_FALLBACK_TO_MOCK=true
NODE_ENV=production
